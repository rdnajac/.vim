{
  "Note": {
    "prefix": "!note",
    "body": "> [!NOTE]\n> ",
    "description": "Note"
  },
  "Tip": {
    "prefix": "!tip",
    "body": "> [!TIP]\n> ",
    "description": "Tip"
  },
  "Important": {
    "prefix": "!important",
    "body": "> [!IMPORTANT]\n> ",
    "description": "Important"
  },
  "Warning": {
    "prefix": "!warning",
    "body": "> [!WARNING]\n> ",
    "description": "Warning"
  },
  "Caution": {
    "prefix": "!caution",
    "body": "> [!CAUTION]\n> ",
    "description": "Caution"
  },
  "Links": {
    "prefix": ["l", "link"],
    "body": ["[${1:text}](${2:url}) ${0}"],
    "description": "Add links"
  },
  "URLS": {
    "prefix": ["u", "url"],
    "body": ["<${1}> ${0}"],
    "description": "Add urls"
  },
  "Images": {
    "prefix": "img",
    "body": ["![${1:alt text}](${2:path}) ${0}"],
    "description": "Add images"
  },
  "code block": {
    "prefix": "codeblock",
    "body": ["```${1:language}", "$0", "```"],
    "description": "fenced code block"
  },
}
