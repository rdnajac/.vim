{
  "Note": {
    "prefix": ["!note", "n"],
    "body": "> [!NOTE]\n> ",
    "description": "Note"
  },
  "Tip": {
    "prefix": ["!tip", "t"],
    "body": "> [!TIP]\n> ",
    "description": "Tip"
  },
  "Important": {
    "prefix": ["!important", "imp"],
    "body": "> [!IMPORTANT]\n> ",
    "description": "Important"
  },
  "Warning": {
    "prefix": ["!warning", "w"],
    "body": "> [!WARNING]\n> ",
    "description": "Warning"
  },
  "Caution": {
    "prefix": ["!caution", "c"],
    "body": "> [!CAUTION]\n> ",
    "description": "Caution"
  },
  "Links": {
    "prefix": ["l", "link"],
    "body": ["[${1:text}](${2:url}) ${0}"],
    "description": "Add links"
  },
  "URLS": {
    "prefix": ["u", "url"],
    "body": ["<${1}> ${0}"],
    "description": "Add urls"
  },
  "Images": {
    "prefix": "img",
    "body": ["![${1:alt text}](${2:path}) ${0}"],
    "description": "Add images"
  },
  "code block": {
    "prefix": "codeblock",
    "body": ["```${1:language}", "$0", "```"],
    "description": "fenced code block"
  },
  "subscript": {
    "prefix": "sub",
    "body": ["${1}<sub>${0}"],
    "description": "Create a subscript."
  },
  "superscript": {
    "prefix": "sup",
    "body": ["${1}<sup>${0}"],
    "description": "Create a superscript."
  },

  "h1": {
    "prefix": "h1",
    "body": ["# ${0}"],
  },
  "h2": {
    "prefix": "h2",
    "body": ["## ${0}"],
  },
  "h3": {
    "prefix": "h3",
    "body": ["### ${0}"],
  },
  "h4": {
    "prefix": "h4",
    "body": ["#### ${0}"],
  },
  "h5": {
    "prefix": "h5",
    "body": ["##### ${0}"],
  },
  "h6": {
    "prefix": "h6",
    "body": ["###### ${0}"],
  },
