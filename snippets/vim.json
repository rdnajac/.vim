{
  "function": {
    "prefix": "function",
    "body": [
      "function! ${1}(${2}) abort",
      "  ${0}",
      "endfunction"
    ],
    "description": "Function definition."
  },

  "autoloadedfunction": {
    "prefix": "auto",
    "body": [
      "function! ${TM_FILENAME_BASE}#${1}(${2}) abort",
      "  ${0}",
      "endfunction"
    ],
    "description": "Autoloaded function definition."
  },

  "if_exists_equals": {
    "prefix": "ife",
    "body": [
      "if !exists('g:${1}')",
      "  let g:${1} = ${2:1}",
      "endif"],
      "description": "Global variable declaration"
  },

  "ifne": {
    "prefix": "if has",
    "prefix": "ifnv",
    "body": ["if ${2}has('{1:nvim}')", "  ${0}", "endif"]
  },

  "command": {
    "prefix": ["cmd", "<Cmd>"],
    "body": "<Cmd>${0}<CR>",
    "description": "Command call."
  },

  "plug": {
    "prefix": "Plug",
    "body": "Plug '${0}'",
    "description": "Plug invocation."
  }
}
